              "raw": "{\n  \"reviewedBy\": \"admin@example.com\",\n  \"note\": \"Approved after verification\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/market-rates/reviews/:reviewId/approve",
              "host": ["{{base_url}}"],
              "path": [
