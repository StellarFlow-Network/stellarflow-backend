    {
      "name": "Price History",
      "item": [
        {
          "name": "Get Asset History (7 days)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/history/:asset?range=7d",
              "host": ["{{base_url}}"],
              "path": ["api", "history", ":asset"],
              "query": [
                {
                  "key": "range",
                  "value": "7d",
                  "description": "Time range: 1d, 7d, 30d, 90d"
                }
              ],
              "variable": [
                {
                  "key": "asset",
                  "value": "NGN",
                  "description": "Asset code (e.g., GHS, NGN, KES)"
                }
              ]
            },
            "description": "Get price history for an asset within specified time range"
          }
        },
        {
          "name": "Get Asset History (Custom Date Range)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/history/:asset?from=2024-01-01&to=2024-01-07",
              "host": ["{{base_url}}"],
              "path": ["api", "history", ":asset"],
              "query": [
                {
                  "key": "from",
                  "value": "2024-01-01",
                  "description": "Start date (ISO 8601)"
                },
                {
                  "key": "to",
                  "value": "2024-01-07",
                  "description": "End date (ISO 8601)"
                }
              ],
              "variable": [
                {
                  "key": "asset",
                  "value": "NGN",
                  "description": "Asset code (e.g., GHS, NGN, KES)"
                }
              ]
            },
            "description": "Get price history for an asset within custom date range"
          }
        }
      ]
    },
    {
      "name": "Price Updates (Multi-Sig)",
      "item": [
        {
          "name": "Create Multi-Sig Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"priceReviewId\": 123,\n  \"currency\": \"NGN\",\n  \"rate\": 0.0021,\n  \"source\": \"NGNX\",\n  \"memoId\": \"memo-123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/price-updates/multi-sig/request",
              "host": ["{{base_url}}"],
              "path": ["api", "price-updates", "multi-sig", "request"]
            },
            "description": "Create a multi-sig price update request"
          }
        },
        {
          "name": "Sign Multi-Sig Price",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{MULTI_SIG_AUTH_TOKEN}}",
                "description": "Multi-sig auth token if configured"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"multiSigPriceId\": 456\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/price-updates/sign",
              "host": ["{{base_url}}"],
              "path": ["api", "price-updates", "sign"]
            },
            "description": "Add signature to a multi-sig price update"
          }
        },
        {
          "name": "Request Remote Signature",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"remoteServerUrl\": \"https://remote-server.example.com/api/price-updates/sign\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/price-updates/multi-sig/:multiSigPriceId/request-signature",
              "host": ["{{base_url}}"],
              "path": [
                "api",
                "price-updates",
                "multi-sig",
                ":multiSigPriceId",
                "request-signature"
              ],
              "variable": [
                {
                  "key": "multiSigPriceId",
                  "value": "456",
                  "description": "Multi-sig price ID"
                }
              ]
            },
            "description": "Request signature from remote server"
          }
        },
        {
          "name": "Get Multi-Sig Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/price-updates/multi-sig/:multiSigPriceId/status",
              "host": ["{{base_url}}"],
              "path": [
                "api",
                "price-updates",
                "multi-sig",
                ":multiSigPriceId",
                "status"
              ],
              "variable": [
                {
                  "key": "multiSigPriceId",
                  "value": "456",
                  "description": "Multi-sig price ID"
                }
              ]
            },
            "description": "Get status of multi-sig price update"
          }
        },
        {
          "name": "Get Pending Multi-Sig Prices",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/price-updates/multi-sig/pending",
              "host": ["{{base_url}}"],
              "path": ["api", "price-updates", "multi-sig", "pending"]
            },
            "description": "Get all pending multi-sig price updates"
          }
        },
        {
          "name": "Get Multi-Sig Signatures",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/price-updates/multi-sig/:multiSigPriceId/signatures",
              "host": ["{{base_url}}"],
              "path": [
                "api",
                "price-updates",
                "multi-sig",
                ":multiSigPriceId",
                "signatures"
              ],
              "variable": [
                {
                  "key": "multiSigPriceId",
                  "value": "456",
                  "description": "Multi-sig price ID"
                }
              ]
            },
            "description": "Get all signatures for approved multi-sig price"
          }
        },
        {
          "name": "Record Submission",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"memoId\": \"memo-123\",\n  \"stellarTxHash\": \"hash-123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/price-updates/multi-sig/:multiSigPriceId/record-submission",
              "host": ["{{base_url}}"],
              "path": [
                "api",
                "price-updates",
                "multi-sig",
                ":multiSigPriceId",
                "record-submission"
              ],
              "variable": [
                {
                  "key": "multiSigPriceId",
                  "value": "456",
                  "description": "Multi-sig price ID"
                }
              ]
            },
            "description": "Record that multi-sig price has been submitted to Stellar"
          }
        }
      ]
    },
