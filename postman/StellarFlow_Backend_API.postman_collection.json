    {
      "name": "System Control (Admin)",
      "item": [
        {
          "name": "Initiate System Halt",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Emergency maintenance required\",\n  \"duration\": 24,\n  \"emergencyLevel\": \"HIGH\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/system/halt",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "system", "halt"]
            },
            "description": "Initiate system halt requiring consensus approval"
          }
        },
        {
          "name": "Initiate System Upgrade",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"version\": \"2.1.0\",\n  \"upgradeType\": \"MINOR\",\n  \"scheduledAt\": \"2024-01-15T10:00:00Z\",\n  \"rollbackPlan\": \"Rollback to previous version\",\n  \"notes\": \"Feature enhancements\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/system/upgrade",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "system", "upgrade"]
            },
            "description": "Initiate system upgrade requiring consensus approval"
          }
        },
        {
          "name": "Add Consensus Signature",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"signature\": \"abcd1234567890...\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/system/consensus/:consensusId/signature",
              "host": ["{{base_url}}"],
              "path": [
                "api",
                "admin",
                "system",
                "consensus",
                ":consensusId",
                "signature"
              ],
              "variable": [
                {
                  "key": "consensusId",
                  "value": "123",
                  "description": "Consensus request ID"
                }
              ]
            },
            "description": "Add admin signature to consensus request"
          }
        },
        {
          "name": "Execute Consensus Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
