              "variable": [
                {
                  "key": "reviewId",
                  "value": "1",
                  "description": "Review ID to approve"
                }
              ]
            },
            "description": "Approve a pending price review"
          }
        },
        {
          "name": "Reject Price Review",
          "request": {
            "method": "POST",
            "header": [
